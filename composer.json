{
  "name": "braesident/js_assets",
  "description": "Load different javascript assets",
  "homepage": "https://www.exunova.de",
  "type": "extension",
  "repositories": [
    {
      "type": "vcs",
      "url": "https://github.com/braesident/Dropdown.git"
    }
  ],
  "require": {
    "php": "^7.4 || ^8.0",
    "braesident/dropdown": "^1.0",
    "matthiasmullie/minify": "^1.3"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.2",
    "squizlabs/php_codesniffer": "^3.6"
  },
  "license": "proprietary",
  "autoload": {
    "psr-4": {
      "exunova\\JsAsset\\": "src/"
    },
    "classmap": [
      "src/"
    ]
  },
  "authors": [
    {
      "name": "Sebastian Braesicke",
      "email": "info@exunova.de",
      "homepage": "https://www.exunova.de",
      "role": "Developer"
    }
  ]
}
